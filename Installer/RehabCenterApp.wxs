<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" 
           Name="مركز التأهيل المتكامل" 
           Language="1033" 
           Version="1.0.0.0" 
           Manufacturer="RehabCenterApp" 
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">

    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="RehabCenterApp" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="ApplicationShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <Icon Id="AppIcon.ico" SourceFile="$(var.ProjectDir)Assets\Iconspp_icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="RehabCenterApp">
          <Component Id="MainExecutable" Guid="*">
            <File Id="RehabCenterApp.exe" Source="$(var.PublishDir)RehabCenterApp.exe" KeyPath="yes" />
          </Component>
          <Component Id="AppIcon" Guid="*">
            <File Id="app_icon.ico" Source="$(var.ProjectDir)Assets\Iconspp_icon.ico" />
          </Component>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="RehabCenterApp">
          <Component Id="ApplicationShortcut" Guid="*">
            <Shortcut Id="ApplicationStartMenuShortcut" 
                      Name="مركز التأهيل المتكامل" 
                      Target="[#RehabCenterApp.exe]"
                      WorkingDirectory="INSTALLFOLDER"
                      Icon="AppIcon.ico" />
            <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\RehabCenterApp" Name="installed" Type="integer" Value="1" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <Directory Id="DesktopFolder" Name="Desktop">
        <Component Id="DesktopShortcut" Guid="*">
          <Shortcut Id="DesktopShortcut" 
                    Name="مركز التأهيل المتكامل" 
                    Target="[#RehabCenterApp.exe]"
                    WorkingDirectory="INSTALLFOLDER"
                    Icon="AppIcon.ico" />
          <RegistryValue Root="HKCU" Key="Software\RehabCenterApp" Name="desktop" Type="integer" Value="1" />
        </Component>
      </Directory>
    </Directory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="AppIcon" />
    </ComponentGroup>

  </Product>
</Wix>